rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write access to the settings configuration
    match /settings/{documentId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
